#!/bin/sh
# Pre-commit gate: customization guard + secret scan (gitleaks) + lint +
# related unit tests for staged JS/TS files.
# Installed via `git config core.hooksPath .githooks` (run automatically by
# the `prepare` npm script after `bun install`).

set -eu

# Recover PATH (git GUIs strip it) and select RUN/RUN_DIRECT. Exits with a
# friendly error if neither bun nor npx is reachable.
. "$(dirname "$0")/_runtime.sh"

# Customization guard first — block commits that stage files owned by an
# ACTIVE customization publish. Publishing copies a customization's files
# straight into the live source tree (lib/server/customization-publish.ts) so
# the running app picks them up; git can't tell them from your own edits, so
# without this gate a `git add -A` sweeps them into main. The guard reads the
# JSON publish records under ~/.claude/.claudius/customizations/ — no app
# runtime needed. Deliberately upstreaming a customization? Bypass once with
# CLAUDIUS_ALLOW_CUSTOMIZATION_COMMIT=1. See scripts/customization-commit-guard.mjs.
if command -v bun >/dev/null 2>&1; then
  bun "$(dirname "$0")/../scripts/customization-commit-guard.mjs"
else
  # _runtime.sh guarantees bun or npx; npx implies node is installed.
  node "$(dirname "$0")/../scripts/customization-commit-guard.mjs"
fi

# Secret scan next — block commits that stage credentials. Runs on ALL
# staged content (not just the JS/TS the lint step below covers): secrets
# hide in .env / yaml / config files too. Same class GitHub's default secret
# scanning catches, but here before the secret ever leaves the machine.
# `_runtime.sh` already put /opt/homebrew/bin on PATH, so gitleaks resolves
# in GUI commit flows too. Soft-skip when gitleaks isn't installed so it's
# not a hard dependency — `brew install gitleaks` turns the gate on. See
# .githooks/README.md.
if command -v gitleaks >/dev/null 2>&1; then
  echo "▶ Scanning staged changes for secrets (gitleaks)…"
  gitleaks git --staged --redact --no-banner
else
  echo "▶ gitleaks not installed — skipping secret scan (brew install gitleaks" \
    "for the secret-scanning coverage GitHub runs)." 1>&2
fi

# Collect staged files (Added/Copied/Modified/Renamed) matching JS/TS
# extensions, that still exist on disk (skip deletions / rename-from paths).
files=$(
  git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '\.(js|jsx|ts|tsx|mjs|cjs)$' \
    | while IFS= read -r f; do
        [ -f "$f" ] && printf '%s\n' "$f"
      done
)

if [ -z "$files" ]; then
  exit 0
fi

count=$(printf '%s\n' "$files" | wc -l | tr -d ' ')

echo "▶ Linting $count staged file(s)…"
# Pass files via xargs so filenames with spaces are handled correctly. The `--`
# separates `bun run lint`'s own flags from the file list it forwards to eslint.
printf '%s\n' "$files" | xargs $RUN lint --

echo "▶ Running related unit tests…"
# `vitest related` walks the module graph and runs only test files that
# (transitively) import any of the staged sources. `--passWithNoTests` keeps
# the hook quiet when a change has no test coverage at all (e.g. config tweaks).
printf '%s\n' "$files" | xargs $RUN test:related --
