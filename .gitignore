# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# next.js
/.next/
# Per-run dist-dir for the e2e Playwright server — keeps its lockfile +
# build cache separate from the user's own `next dev`. See
# playwright.config.ts.
/.next-e2e/
/out/

# electron build outputs
/dist-electron/
/release/

# electron e2e Ralph loop audit log (per-iteration entries; not pushed)
tests/electron/LOOP.log

# ralph-loop session state (per-session, not portable)
/.claude/ralph-loop.local.md
# ralph-loop task checklist + plugin-granted local permissions (local scratch)
/.claude/ralph-state/
/.claude/settings.json
# agent git worktrees (created per-session; not portable, never committed)
/.claude/worktrees/

# claudiusd runtime state (pid file, logs)
/.claudius/

# local sqlite data (chat db + WAL/SHM sidecars)
/data/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
